#!/usr/bin/env bash

set -euo pipefail

STATE_DIR="/var/lib/vapor"
STATE_FILE="$STATE_DIR/state"

USER_NAME="vapor"
HOME_BASE="/var/home"

VAPOR_GROUPS=(
    video
    render
    audio
    input
)

if (( EUID != 0 )); then
    echo "error: this script must be executed as root."
    exit 1
fi


if [[ -f "$STATE_FILE" ]]; then
    echo "info: system already initialized."
    exit 0
fi


if id "$USER_NAME" &>/dev/null; then
    echo "info: user already exists."
    exit 0
fi

USER_HOME="$HOME_BASE/$USER_NAME"

GROUP_ARGS=()

for group in "${VAPOR_GROUPS[@]}"; do
    if getent group "$group" >/dev/null; then
        GROUP_ARGS+=("$group")
    fi
done

useradd \
    --create-home \
    --home-dir "$USER_HOME" \
    --shell /bin/bash \
    ${GROUP_ARGS:+--groups "$(IFS=,; echo "${GROUP_ARGS[*]}")"} \
    "$USER_NAME"


passwd -d "$USER_NAME" >/dev/null

mkdir -p \
    "$USER_HOME/.config" \
    "$USER_HOME/.cache" \
    "$USER_HOME/.local/share"

chown -R "$USER_NAME:$USER_NAME" "$USER_HOME"


loginctl enable-linger "$USER_NAME"

mkdir -p "$STATE_DIR"

cat >"$STATE_FILE" <<EOF
VERSION=1
USER=$USER_NAME
EOF

chmod 700 "$STATE_DIR"
chmod 600 "$STATE_FILE"

echo "info: vapor provision completed."
